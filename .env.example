# Signal Brain — Phase 2 environment.
# Copy to .env.local for Next.js dev (and .env for tsx scripts). Never commit real secrets.

# Claude API — the runtime ranking call (claude-sonnet-4-6).
ANTHROPIC_API_KEY=

# Neon Postgres connection string (pooled). Provided by the Vercel Neon integration in prod;
# for local dev point this at a Neon dev branch (same engine as prod — no local SQLite).
DATABASE_URL=

# Telegram bot — created via BotFather. The bot token, and the single allow-listed chat id
# (your own). Captures/callbacks from any other chat id are ignored.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Shared secret passed to Telegram setWebhook (secret_token) and checked on each webhook
# request via the X-Telegram-Bot-Api-Secret-Token header. Any random high-entropy string.
TELEGRAM_WEBHOOK_SECRET=

# Shared secret for the Vercel Cron trigger. Vercel sends `Authorization: Bearer $CRON_SECRET`
# on scheduled invocations; the digest route rejects anything else. Any random string.
CRON_SECRET=
