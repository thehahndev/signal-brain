# Copy to spike/.env and fill in. spike/.env is gitignored.

# THE CRUX — get a key + a few $ credit. https://twitterapi.io
TWITTERAPI_IO_KEY=
# Optional override. Default (in code) is the verified thread/conversation endpoint:
#   https://api.twitterapi.io/twitter/tweet/thread_context?tweetId={id}  (pagination followed)
# Use {id} as the tweet-id placeholder. Only set this to point at a different endpoint.
# TWITTERAPI_IO_ENDPOINT=https://api.twitterapi.io/twitter/tweet/thread_context?tweetId={id}

# Optional baseline comparison for X + articles (cheap scrape). https://firecrawl.dev
FIRECRAWL_KEY=

# Optional — Jina Reader works keyless on the free tier; a key raises limits. https://jina.ai/reader
JINA_KEY=
